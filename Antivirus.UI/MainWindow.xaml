<Window x:Class="Antivirus.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Antivirus.UI"
        mc:Ignorable="d"
        Title="Antivirus UI" Height="300" Width="900">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
            <Button x:Name="PickFileButton" Width="140" Height="32" Click="PickFileButton_Click">Выбрать файл</Button>
            <Button x:Name="ScanDirectoryButton" Width="140" Height="32" Margin="8,0,0,0" Click="ScanDirectoryButton_Click">Сканировать папку</Button>
            <Button x:Name="QuarantineFileButton" Width="160" Height="32" Margin="8,0,0,0" Click="QuarantineFileButton_Click">Поместить в карантин</Button>
            <Button x:Name="OpenQuarantineButton" Width="140" Height="32" Margin="8,0,0,0" Click="OpenQuarantineButton_Click">Карантин</Button>
            <TextBlock VerticalAlignment="Center" Margin="8,0,0,0" Text="For Yara+++" />
        </StackPanel>

        <TextBox x:Name="ResultTextBox" Grid.Row="1" Margin="0,12,0,12" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>

        <TextBlock Grid.Row="2" Foreground="Gray" FontSize="11" Text="Сканирование Антивирусом schalun version." />
    </Grid>
</Window>